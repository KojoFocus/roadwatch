# ─── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# Get from: https://neon.tech → your project → Connection string
# Use the "pooled" connection for DATABASE_URL and "direct" for DIRECT_URL
DATABASE_URL="postgresql://user:password@host/roadwatch?sslmode=require"
DIRECT_URL="postgresql://user:password@host/roadwatch?sslmode=require"

# ─── Gemini AI ─────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key"

# ─── Supabase Storage (photos + audio) ────────────────────────────────────────
# Get from: https://supabase.com → your project → Settings → API
# Create two public buckets before deploying:
#   - report-photos  (public, image/*, 5MB max)
#   - report-audio   (public, audio/*, 10MB max)
# In Storage → Policies, add a public INSERT policy for both buckets using the anon key.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_KEY="your-service-role-key"

# ─── Session (admin auth) ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Or PowerShell: -join ((1..32) | % { '{0:x2}' -f (Get-Random -Max 256) })
SESSION_SECRET="generate-a-64-char-hex-string-here"

# ─── App URLs ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
